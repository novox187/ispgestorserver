# ── Copia este archivo como variables de entorno en Coolify ──────────────────
# NO commitear con secretos reales — usa el panel de Coolify para inyectarlos

APP_NAME="ISP Gestor"
APP_ENV=production
APP_KEY=base64:REEMPLAZAR_CON_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://api.ironlink.uk

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=America/Bogota

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=REEMPLAZAR_CON_HOST_BD
DB_PORT=3306
DB_DATABASE=isp_gestor
DB_USERNAME=REEMPLAZAR
DB_PASSWORD=REEMPLAZAR

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.ironlink.uk
SESSION_SECURE_COOKIE=true

# Dominios SPA autorizados para autenticación con cookies (Sanctum)
SANCTUM_STATEFUL_DOMAINS=ironlink.uk,admin.ironlink.uk

# CORS: sólo los frontends de producción
CORS_ALLOWED_ORIGINS=https://ironlink.uk,https://admin.ironlink.uk
CORS_SUPPORTS_CREDENTIALS=true

BROADCAST_CONNECTION=reverb

# Reverb — el servidor escucha en :8080 internamente; nginx lo proxea por :80
# Coolify termina SSL en :443 → nginx en :80 → Reverb en :8080
REVERB_APP_ID=isp-chat
REVERB_APP_KEY=isp-chat-key
REVERB_APP_SECRET=REEMPLAZAR_CON_SECRETO_SEGURO
REVERB_HOST=api.ironlink.uk
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@ironlink.uk"
MAIL_FROM_NAME="${APP_NAME}"

# MikroTik API (RouterOS)
MIKROTIK_HOST=192.168.20.1
MIKROTIK_USER=REEMPLAZAR
MIKROTIK_PASS=REEMPLAZAR
MIKROTIK_PORT=8728
MIKROTIK_TIMEOUT=10
MIKROTIK_ATTEMPTS=10
MIKROTIK_DELAY=1

MIKROTIK_REST_BASE_URL=https://192.168.20.1/rest
MIKROTIK_REST_USER=${MIKROTIK_USER}
MIKROTIK_REST_PASS=${MIKROTIK_PASS}
MIKROTIK_TLS_VERIFY=true
MIKROTIK_REST_TIMEOUT=10

CLOUDINARY_URL=REEMPLAZAR_CON_CLOUDINARY_URL
CLOUDINARY_UPLOAD_PRESET=ispgestor
CLOUDINARY_NOTIFICATION_URL=https://cloudinary.com/api/v1_1/REEMPLAZAR/notifications

# ── Billing Workers ──────────────────────────────────────────────────────────
BILLING_SUSPENSION_GRACE_DAYS=3
BILLING_TIMEZONE=America/Bogota
BILLING_SCHEDULE_INVOICE_DAY=1
BILLING_SCHEDULE_INVOICE_TIME=00:05
BILLING_SCHEDULE_PAYMENTS_TIME=02:00
BILLING_SCHEDULE_SUSPEND_TIME=08:00
BILLING_SCHEDULE_REACTIVATE_TIME=10:00
BILLING_SCHEDULE_MKSYNC_HOUR1=6
BILLING_SCHEDULE_MKSYNC_HOUR2=18
BILLING_QUEUE_SUSPENSIONS=suspensions
BILLING_QUEUE_REACTIVATIONS=reactivations
